# PostgreSQL — Supabase (Transaction Pooler)
POSTGRES_URL=postgresql://user:password@aws-1-us-west-2.pooler.supabase.com:6543/postgres
POSTGRES_SSL=true

# MongoDB — Atlas M0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ecommify?appName=ecommify

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h
